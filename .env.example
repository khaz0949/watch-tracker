# Chrono24 live prices via Retailed.io (recommended for reliable performance tracking).
# Sign up at https://www.retailed.io/ and add your API key. Then run: npm run refresh-chrono24
# RETAILED_API_KEY=your_retailed_api_key

# If your Retailed plan has limited requests, set to true to refresh only Rolex, AP, Patek, Cartier, Richard Mille (~65 models)
# REFRESH_CORE_ONLY=true

# Optional: limit how many watches to refresh (e.g. 10 for testing or very small quota)
# REFRESH_LIMIT=10

# Optional: protect cron endpoint. Pass ?secret=CRON_SECRET when calling /api/cron/refresh-chrono24
# CRON_SECRET=your_secret

# Optional: real historical prices from TheWatchAPI at seed time (Standard plan+).
# THEWATCHAPI_API_TOKEN=your_api_token_here
